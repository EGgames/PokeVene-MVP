# PokeVene Backend — Variables de Entorno
# Copiar a .env y completar con valores reales. NUNCA hacer commit de .env.

# Servidor
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=pokevene_user
DB_PASSWORD=your_db_password_here
DB_NAME=pokevene_db
DB_POOL_MAX=10

# JWT (SPEC-002: mínimo 32 caracteres, expira en 7 días)
JWT_SECRET=your_jwt_secret_at_least_32_characters_here
JWT_EXPIRES_IN=7d
